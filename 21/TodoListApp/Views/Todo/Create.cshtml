@model TodoListApp.Models.TodoItem

<div class="form-wrapper">

    <h2>Новая задача</h2>

    <form asp-action="Create">

        <div class="form-group">

            <label asp-for="Title">
                Название задачи
            </label>

            <input asp-for="Title"
                   class="form-input" />

        </div>

        <div class="form-group">

            <label asp-for="Deadline">
                Срок выполнения
            </label>

            <input asp-for="Deadline"
                   type="date"
                   class="form-input" />

        </div>

        <div class="form-actions">

            <button type="submit"
                    class="btn-submit">

                Добавить

            </button>

            <a asp-action="Index"
               class="btn-cancel">

                Отмена

            </a>

        </div>

    </form>

</div>