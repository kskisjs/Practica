<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ControlTemplate для кнопки "Сохранить изменения".
        Кастомный дизайн: скруглённые углы, цветной фон,
        анимация при наведении и нажатии, затемнение при недоступности.
    -->
    <ControlTemplate x:Key="SaveButtonTemplate" TargetType="{x:Type Button}">
        <Border x:Name="RootBorder"
                CornerRadius="8"
                Padding="20,10"
                Background="#1976D2"
                BorderThickness="0"
                SnapsToDevicePixels="True">

            <!-- Внутренний слой для анимации подсветки -->
            <Border x:Name="HighlightLayer"
                    CornerRadius="8"
                    Background="White"
                    Opacity="0">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RecognizesAccessKey="True"/>
            </Border>
        </Border>

        <ControlTemplate.Triggers>

            <!-- Наведение мыши — осветляем фон -->
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#1565C0"
                                            Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetName="HighlightLayer"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.07"
                                             Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#1976D2"
                                            Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetName="HighlightLayer"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>

            <!-- Нажатие — тёмный фон + масштаб -->
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="RootBorder" Property="Background" Value="#0D47A1"/>
                <Setter TargetName="RootBorder" Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="0.5" CenterY="0.5"/>
                    </Setter.Value>
                </Setter>
            </Trigger>

            <!-- Недоступна — полупрозрачность -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="RootBorder" Property="Background" Value="#BDBDBD"/>
                <Setter TargetName="RootBorder" Property="Opacity" Value="0.6"/>
            </Trigger>

        </ControlTemplate.Triggers>
    </ControlTemplate>


    <!-- Стиль кнопки "Сохранить изменения", использующий шаблон выше -->
    <Style x:Key="SaveButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Template"    Value="{StaticResource SaveButtonTemplate}"/>
        <Setter Property="Foreground"  Value="White"/>
        <Setter Property="FontSize"    Value="14"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="MinWidth"    Value="160"/>
    </Style>


    <!--
        ControlTemplate для кнопки-иконки (удалить / добавить).
        Круглая кнопка без рамки.
    -->
    <ControlTemplate x:Key="IconButtonTemplate" TargetType="{x:Type Button}">
        <Border x:Name="Bd"
                Width="36" Height="36"
                CornerRadius="18"
                Background="Transparent">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#1A000000"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#33000000"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Template" Value="{StaticResource IconButtonTemplate}"/>
        <Setter Property="Cursor"   Value="Hand"/>
        <Setter Property="Padding"  Value="0"/>
    </Style>

</ResourceDictionary>
