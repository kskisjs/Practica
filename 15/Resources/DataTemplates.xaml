<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:CRMApp.Models"
                    xmlns:converters="clr-namespace:CRMApp.Converters">

    <!-- Конвертеры -->
    <converters:ClientTypeToColorConverter x:Key="ClientTypeToColorConverter"/>
    <converters:ClientTypeToTextConverter  x:Key="ClientTypeToTextConverter"/>

    <!--
        DataTemplate для одного элемента в ListBox.
        Показывает: ФИО (жирный), телефон, email и цветной бейдж типа клиента.
    -->
    <DataTemplate x:Key="ClientItemTemplate" DataType="{x:Type models:ClientModel}">
        <Border Padding="12,10"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0"
                Background="Transparent">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Левая часть: данные клиента -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">

                    <TextBlock Text="{Binding FullName}"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#212121"/>

                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="📞 "
                                   FontSize="12"
                                   Foreground="#757575"/>
                        <TextBlock Text="{Binding Phone}"
                                   FontSize="12"
                                   Foreground="#757575"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                        <TextBlock Text="✉ "
                                   FontSize="12"
                                   Foreground="#757575"/>
                        <TextBlock Text="{Binding Email}"
                                   FontSize="12"
                                   Foreground="#757575"/>
                    </StackPanel>
                </StackPanel>

                <!-- Правая часть: бейдж VIP / Обычный -->
                <Border Grid.Column="1"
                        CornerRadius="12"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        Background="{Binding ClientType,
                            Converter={StaticResource ClientTypeToColorConverter}}">
                    <TextBlock Text="{Binding ClientType,
                                   Converter={StaticResource ClientTypeToTextConverter}}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#333333"/>
                </Border>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
