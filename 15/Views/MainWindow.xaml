<Window x:Class="CRMApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CRMApp.ViewModels"
        Title="CRM — Управление клиентами"
        Height="680" Width="1000"
        MinHeight="500" MinWidth="750"
        Background="{StaticResource BackgroundBrush}">

    <!--
        DataContext задаётся здесь.
        Все ресурсы (конвертеры, шаблоны, стили) объявлены ТОЛЬКО в App.xaml → AppResources.xaml.
        В Window.Resources ничего не добавляем — это устраняет конфликт типов XDG-0002.
    -->
    <Window.DataContext>
        <vm:CRMViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- ═══════ ШАПКА ═══════ -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="20,0">
                <TextBlock Text="CRM — Клиентская база"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Content="↻ Обновить"
                        Command="{Binding LoadClientsCommand}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Background="Transparent"
                        BorderBrush="#80FFFFFF"
                        BorderThickness="1"
                        Padding="12,6"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- ═══════ ОСНОВНОЙ КОНТЕНТ ═══════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── ЛЕВАЯ ПАНЕЛЬ: список клиентов ─── -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource SeparatorBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Кнопка «Добавить» -->
                    <Border Grid.Row="0"
                            Padding="12,10"
                            BorderBrush="{StaticResource SeparatorBrush}"
                            BorderThickness="0,0,0,1">
                        <Button Content="+ Добавить клиента"
                                Command="{Binding AddClientCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch"/>
                    </Border>

                    <!--
                        ListBox:
                        - ItemsSource привязан к ObservableCollection<ClientModel>
                        - SelectedItem — TwoWay-привязка
                        - ItemTemplate ссылается на ClientItemTemplate из AppResources.xaml
                    -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Clients}"
                             SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                             ItemTemplate="{StaticResource ClientItemTemplate}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             BorderThickness="0"
                             Background="Transparent"/>

                    <!-- Индикатор загрузки -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8"
                                Visibility="{Binding IsLoading,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar IsIndeterminate="True"
                                     Width="140" Height="4"
                                     Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="  Загрузка..."
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── ПРАВАЯ ПАНЕЛЬ: форма редактирования ───
                 Grid (не Border!) — чтобы разместить два дочерних элемента:
                 placeholder и ScrollViewer с формой.
            -->
            <Grid Grid.Column="1" Background="{StaticResource SurfaceBrush}">

                <!-- Placeholder — когда клиент не выбран -->
                <TextBlock Text="Выберите клиента из списка"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="{StaticResource TextSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedClient}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Форма — когда клиент выбран -->
                <ScrollViewer>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedClient}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>

                    <StackPanel Margin="32,24">

                        <TextBlock Text="Данные клиента"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedClient.FullName}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,20"/>

                        <!-- ФИО — TwoWay -->
                        <TextBlock Text="ФИО" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditFullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Телефон — TwoWay -->
                        <TextBlock Text="Телефон" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Email — TwoWay -->
                        <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Тип клиента — ComboBox, OneWay привязка источника, TwoWay выбора -->
                        <TextBlock Text="Тип клиента" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding ClientTypeValues, Mode=OneWay}"
                                  SelectedItem="{Binding EditClientType, Mode=TwoWay}"/>

                        <!-- Кнопки -->
                        <StackPanel Orientation="Horizontal" Margin="0,28,0,16">
                            <Button Content="💾 Сохранить изменения"
                                    Command="{Binding SaveClientCommand}"
                                    Style="{StaticResource SaveButtonStyle}"
                                    Foreground="White"
                                    Margin="0,0,12,0"/>
                            <Button Content="🗑 Удалить клиента"
                                    Command="{Binding DeleteClientCommand}"
                                    Style="{StaticResource DangerButtonStyle}"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ═══════ СТАТУСБАР ═══════ -->
        <Border Grid.Row="2"
                Background="#EEEEEE"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Всего клиентов: "/>
                    <Run Text="{Binding Clients.Count, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>

    </Grid>
</Window>
