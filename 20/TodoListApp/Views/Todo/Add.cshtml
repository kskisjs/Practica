@using TodoListApp.ViewModels
@model TaskViewModel
@{
    ViewData["Title"] = "Добавить задачу";
}

<div class="form-wrapper">
    <h2>➕ Новая задача</h2>

    <form asp-action="Add" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Description"></label>
            <input asp-for="Description" class="form-input" placeholder="Например: Подготовить отчёт" autofocus />
            <span asp-validation-for="Description" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="DueDate"></label>
            <input asp-for="DueDate" type="date" class="form-input" />
            <span asp-validation-for="DueDate" class="validation-error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">Добавить</button>
            <a href="/Todo" class="btn-cancel">Отмена</a>
        </div>
    </form>
</div>
