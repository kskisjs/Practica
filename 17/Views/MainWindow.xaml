<Window x:Class="CRMApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CRMApp.ViewModels"
        Title="CRM — Управление клиентами" Width="1200" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Loaded="Window_Loaded">

    <!-- ══════════════════════════════════════════════════════════════
         WINDOW-LEVEL STORYBOARDS
         Эти анимации запускаются из code-behind по событиям окна
    ══════════════════════════════════════════════════════════════ -->
    <Window.Resources>

        <!-- FadeIn всего окна при запуске -->
        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- SlideIn + FadeIn для карточки клиента (выезд справа) -->
        <Storyboard x:Key="ClientCardSlideIn">
            <DoubleAnimation Storyboard.TargetName="ClientDetailPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetName="ClientDetailPanel"
                                Storyboard.TargetProperty="Margin"
                                From="30,0,-30,8" To="0,0,0,8" Duration="0:0:0.35">
                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <!-- ExpandCard — разворачивание секции заказов -->
        <Storyboard x:Key="OrdersExpandIn">
            <DoubleAnimation Storyboard.TargetName="OrdersPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
            <ThicknessAnimation Storyboard.TargetName="OrdersPanel"
                                Storyboard.TargetProperty="Margin"
                                From="0,12,0,-12" To="0,0,0,0" Duration="0:0:0.35">
                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <!-- Пульсация бейджа уведомлений -->
        <Storyboard x:Key="BadgePulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="NotifBadge"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1.0" To="1.18" Duration="0:0:0.7" AutoReverse="True">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="NotifBadge"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1.0" To="1.18" Duration="0:0:0.7" AutoReverse="True">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ShakeAnimation для статус-бара при ошибке -->
        <Storyboard x:Key="StatusShake">
            <ThicknessAnimation Storyboard.TargetName="StatusBar"
                                Storyboard.TargetProperty="Margin"
                                From="0,0,0,0" To="6,0,-6,0"
                                Duration="0:0:0.05" AutoReverse="True"
                                RepeatBehavior="3x"/>
        </Storyboard>

    </Window.Resources>

    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ── Шапка ─────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#2A2A3E">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🏢 CRM Система" FontSize="18" FontWeight="Bold"
                           Foreground="#7C8CF8" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Foreground="#8A8AAA" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Run Text="👤 "/>
                        <Run Text="{Binding CurrentUser.FullName}"/>
                        <Run Text=" ("/>
                        <Run Text="{Binding CurrentUser.Role}"/>
                        <Run Text=")"/>
                    </TextBlock>
                    <Button Content="Выйти" Style="{DynamicResource DangerButtonStyle}"
                            Click="OnLogout" Height="30" Padding="12,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Основные вкладки ───────────────────────────────────── -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTab}"
                    Background="Transparent" BorderThickness="0" Margin="0"
                    SelectionChanged="TabControl_SelectionChanged">

            <!-- ─── Клиенты ─────────────────────────────────────── -->
            <TabItem Header="👥 Клиенты" Style="{DynamicResource TabItemStyle}">
                <Grid x:Name="ClientsTabContent" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" MinWidth="240"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Панель списка клиентов -->
                    <Border Background="#2A2A3E" CornerRadius="10" Grid.Column="0"
                            Effect="{StaticResource CardShadow}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Список клиентов" Foreground="#7C8CF8"
                                       FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>

                            <TextBox Grid.Row="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource InputTextBoxStyle}"
                                     Tag="🔍 Поиск..." Margin="0,0,0,10"/>

                            <!-- ── ListBox с ColorAnimation на каждом элементе ── -->
                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding FilteredClients}"
                                     SelectedItem="{Binding SelectedClient}"
                                     Style="{DynamicResource ClientListBoxStyle}"
                                     ItemContainerStyle="{DynamicResource ClientListItemStyle}"
                                     SelectionChanged="ClientList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding FullName}" Foreground="#E0E0F0"
                                                           FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding Company}" Foreground="#8A8AAA" FontSize="11"/>
                                                <TextBlock Text="{Binding Phone}"   Foreground="#7A7A9A" FontSize="11"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                    Background="{Binding ClientType, Converter={StaticResource ClientTypeToColorConverter}}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ClientType}" Foreground="White" FontSize="10"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="+ Добавить" Command="{Binding AddClientCommand}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Height="32" Padding="12,0" Margin="0,0,6,0"/>
                                <Button Content="🔄" Command="{Binding LoadClientsCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="32" Width="36"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="Transparent"/>

                    <!-- Правая панель: карточка + заказы -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ── Карточка клиента — выезжает с анимацией SlideInFromRight ── -->
                        <Border x:Name="ClientDetailPanel"
                                Background="#2A2A3E" CornerRadius="10"
                                Margin="0,0,0,8"
                                Opacity="0"
                                Effect="{StaticResource CardShadow}"
                                Visibility="{Binding SelectedClient, Converter={StaticResource NullToVisibilityConverter}}">
                            <Grid Margin="20,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Заголовок карточки — кликабелен для сворачивания/разворачивания -->
                                <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal"
                                            Margin="0,0,0,12"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="ToggleClientCard">
                                    <TextBlock Text="Карточка клиента"
                                               Foreground="#7C8CF8" FontWeight="SemiBold" FontSize="14"/>
                                    <TextBlock x:Name="CardToggleArrow" Text=" ▲"
                                               Foreground="#7C8CF8" FontSize="12"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>

                                <!-- Разворачивающееся содержимое карточки (HeightAnimation) -->
                                <StackPanel x:Name="ClientCardBody"
                                            Grid.Row="1" Grid.Column="0"
                                            Margin="0,0,8,10">
                                    <TextBlock Text="Полное имя" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding EditFullName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource InputTextBoxStyle}"/>
                                </StackPanel>

                                <StackPanel x:Name="ClientCardBody2"
                                            Grid.Row="1" Grid.Column="1"
                                            Margin="8,0,0,10">
                                    <TextBlock Text="Компания" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding EditCompany, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource InputTextBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,10">
                                    <TextBlock Text="Телефон" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource InputTextBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,10">
                                    <TextBlock Text="Email" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource InputTextBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,10">
                                    <TextBlock Text="Тип клиента" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding ClientTypeValues}"
                                              SelectedItem="{Binding EditClientType}"
                                              Style="{DynamicResource ComboBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                    <TextBlock Text="Заметки" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource InputTextBoxStyle}"
                                             TextWrapping="Wrap" Height="52" AcceptsReturn="True"/>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal">
                                    <Button Content="💾 Сохранить" Command="{Binding SaveClientCommand}"
                                            Style="{DynamicResource PrimaryButtonStyle}"
                                            Height="34" Padding="16,0" Margin="0,0,8,0"/>
                                    <Button Content="🗑 Удалить" Command="{Binding DeleteClientCommand}"
                                            Style="{DynamicResource DangerButtonStyle}"
                                            Height="34" Padding="16,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── Заказы клиента — появляются с FadeInUp ── -->
                        <Border x:Name="OrdersPanel"
                                Background="#2A2A3E" CornerRadius="10" Grid.Row="1"
                                Opacity="0"
                                Effect="{StaticResource CardShadow}"
                                Visibility="{Binding SelectedClient, Converter={StaticResource NullToVisibilityConverter}}">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Заказы / Сделки" Foreground="#7C8CF8"
                                                   FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                        <Button Content="+ Добавить заказ" Command="{Binding AddOrderCommand}"
                                                Style="{DynamicResource PrimaryButtonStyle}"
                                                Height="26" Padding="10,0" Margin="12,0,0,0" FontSize="11"/>
                                    </StackPanel>

                                    <DataGrid Grid.Row="1" ItemsSource="{Binding ClientOrders}"
                                              SelectedItem="{Binding SelectedOrder}"
                                              Style="{DynamicResource DataGridStyle}"
                                              AutoGenerateColumns="False" CanUserAddRows="False"
                                              IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID"       Binding="{Binding Id}"           Width="40"/>
                                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}"  Width="*"/>
                                            <DataGridTextColumn Header="Сумма"    Binding="{Binding Amount, StringFormat={}{0:N0} ₽}" Width="100"/>
                                            <DataGridTextColumn Header="Статус"   Binding="{Binding Status}"       Width="100"/>
                                            <DataGridTextColumn Header="Дата"     Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>

                                <!-- Редактирование заказа -->
                                <Border Grid.Column="1" Margin="12,0,0,0"
                                        Visibility="{Binding SelectedOrder, Converter={StaticResource NullToVisibilityConverter}}">
                                    <StackPanel Margin="8,0">
                                        <TextBlock Text="Редактирование заказа" Foreground="#7C8CF8"
                                                   FontWeight="SemiBold" Margin="0,0,0,10"/>

                                        <TextBlock Text="Описание" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding EditOrderDesc, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{DynamicResource InputTextBoxStyle}"
                                                 TextWrapping="Wrap" Height="52" AcceptsReturn="True" Margin="0,0,0,10"/>

                                        <TextBlock Text="Сумма (₽)" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding EditOrderAmount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{DynamicResource InputTextBoxStyle}" Margin="0,0,0,10"/>

                                        <TextBlock Text="Статус" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,3"/>
                                        <ComboBox ItemsSource="{Binding OrderStatusValues}"
                                                  SelectedItem="{Binding EditOrderStatus}"
                                                  Style="{DynamicResource ComboBoxStyle}" Margin="0,0,0,14"/>

                                        <Button Content="💾 Сохранить" Command="{Binding SaveOrderCommand}"
                                                Style="{DynamicResource PrimaryButtonStyle}" Height="32" Margin="0,0,0,6"/>
                                        <Button Content="🗑 Удалить" Command="{Binding DeleteOrderCommand}"
                                                Style="{DynamicResource DangerButtonStyle}" Height="32"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─── Чат ─────────────────────────────────────────── -->
            <TabItem Header="💬 Чат" Style="{DynamicResource TabItemStyle}">
                <Grid x:Name="ChatTabContent" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="#2A2A3E" CornerRadius="10"
                            Effect="{StaticResource CardShadow}">
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Корпоративный чат" Foreground="#7C8CF8"
                                       FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>

                            <ScrollViewer Grid.Row="1" x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Chat.Messages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#32324A" CornerRadius="8"
                                                    Margin="0,0,0,8" Padding="12,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Foreground="#7C8CF8" FontWeight="SemiBold" FontSize="12">
                                                            <Run Text="{Binding SenderFullName}"/>
                                                            <Run Text=" (@"/>
                                                            <Run Text="{Binding SenderUsername}"/>
                                                            <Run Text=")"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Text}" Foreground="#E0E0F0"
                                                                   TextWrapping="Wrap" FontSize="13" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding SentAt, StringFormat=HH:mm}"
                                                               Foreground="#666680" FontSize="10" VerticalAlignment="Top"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Grid Grid.Row="2" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding Chat.NewMessage, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource InputTextBoxStyle}"
                                         Tag="Введите сообщение..."
                                         KeyDown="OnChatKeyDown"/>
                                <Button Grid.Column="1" Content="➤ Отправить"
                                        Command="{Binding Chat.SendCommand}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Height="36" Padding="16,0" Margin="8,0,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─── Уведомления ───────────────────────────────────── -->
            <TabItem Style="{DynamicResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔔 Уведомления"/>
                        <!-- Пульсирующий бейдж с ScaleTransform -->
                        <Border x:Name="NotifBadge"
                                CornerRadius="8" Background="#E74C3C"
                                Padding="4,1" Margin="6,0,0,0"
                                RenderTransformOrigin="0.5,0.5"
                                Visibility="{Binding UnreadCount, Converter={StaticResource IntToVisibilityConverter}}">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <TextBlock Text="{Binding UnreadCount}" Foreground="White"
                                       FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <Grid x:Name="NotifTabContent" Margin="20">
                    <Border Background="#2A2A3E" CornerRadius="10"
                            Effect="{StaticResource CardShadow}">
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Уведомления" Foreground="#7C8CF8"
                                           FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                <Button Content="✓ Прочитать все"
                                        Command="{Binding MarkNotificationsReadCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="28" Padding="10,0" Margin="12,0,0,0"/>
                                <Button Content="🔄" Command="{Binding RefreshNotificationsCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="28" Width="36" Margin="6,0,0,0"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Notifications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Визуальный эффект: плавная смена фона у непрочитанных -->
                                            <Border CornerRadius="8" Margin="0,0,0,6" Padding="14,10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#32324A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                                <Setter Property="Background" Value="#2D2D50"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Trigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <ColorAnimation
                                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                To="#3C3C5E" Duration="0:0:0.2"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <ColorAnimation
                                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                To="#32324A" Duration="0:0:0.2"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border CornerRadius="4" Width="6" Margin="0,0,10,0"
                                                            Background="{Binding IsRead, Converter={StaticResource ReadToColorConverter}}"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}" Foreground="#E0E0F0"
                                                                   FontWeight="SemiBold" FontSize="13"/>
                                                        <TextBlock Text="{Binding Message}" Foreground="#AAAACC"
                                                                   FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Foreground="#666680" FontSize="10"
                                                               VerticalAlignment="Top"
                                                               Text="{Binding CreatedAt, StringFormat=dd.MM HH:mm}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ── Строка статуса ─────────────────────────────────────── -->
        <Border x:Name="StatusBar" Grid.Row="2" Background="#2A2A3E">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#8A8AAA"
                           FontSize="12" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" IsIndeterminate="{Binding IsLoading}"
                             Width="120" Height="4"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                             Foreground="#7C8CF8" Background="#444455"/>
            </Grid>
        </Border>

    </Grid>
</Window>
