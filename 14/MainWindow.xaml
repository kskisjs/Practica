<Window x:Class="CRMApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CRM - Система управления клиентами" 
        Height="600" 
        Width="850"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ✅ DataTemplate для отображения списка клиентов с ФИО, телефоном и статусом (VIP/обычный) -->
        <DataTemplate x:Key="ClientCardTemplate">
            <Border BorderBrush="#4A90E2" BorderThickness="1" CornerRadius="8" Margin="5" Padding="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="VIP">
                                <Setter Property="Background" Value="#FFF8E1"/>
                                <Setter Property="BorderBrush" Value="#FFD700"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <StackPanel>
                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding Phone}" FontSize="12" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding Email}" FontSize="11" Foreground="Gray"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Статус: " FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Status}" FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="VIP">
                                            <Setter Property="Foreground" Value="#FF9800"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ✅ ControlTemplate для кнопки "Сохранить" с кастомным дизайном -->
        <ControlTemplate x:Key="SaveButtonTemplate" TargetType="Button">
            <Border Background="#27AE60" CornerRadius="10" Padding="15,8">
                <Border.Resources>
                    <Storyboard x:Key="MouseEnter">
                        <ColorAnimation Storyboard.TargetName="border"
                                        Storyboard.TargetProperty="Background.Color"
                                        To="#219A52" Duration="0:0:0.2"/>
                    </Storyboard>
                </Border.Resources>
                <Border x:Name="border" Background="#27AE60" CornerRadius="10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="✓ " Foreground="White" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="Сохранить изменения" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Border>
        </ControlTemplate>

        <!-- ✅ ControlTemplate для кнопки "Отмена" -->
        <ControlTemplate x:Key="CancelButtonTemplate" TargetType="Button">
            <Border Background="#E74C3C" CornerRadius="10" Padding="15,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="✗ " Foreground="White" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="Отменить" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </ControlTemplate>
    </Window.Resources>

    <!-- ГОРЯЧИЕ КЛАВИШИ -->
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- МЕНЮ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="Клиенты">
                <MenuItem Header="Добавить" Command="{Binding AddCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="Редактировать" Command="{Binding EditCommand}" InputGestureText="Ctrl+E"/>
                <Separator/>
                <MenuItem Header="Удалить" Command="{Binding DeleteCommand}" InputGestureText="Ctrl+D"/>
            </MenuItem>
            <MenuItem Header="Настройки">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- ПАНЕЛЬ ИНСТРУМЕНТОВ -->
        <ToolBar DockPanel.Dock="Top" Height="50">
            <Button Command="{Binding AddCommand}" ToolTip="Добавить (Ctrl+N)">➕ Добавить</Button>
            <Button Command="{Binding EditCommand}" ToolTip="Редактировать (Ctrl+E)">✏️ Редактировать</Button>
            <Button Command="{Binding DeleteCommand}" ToolTip="Удалить (Ctrl+D)">🗑️ Удалить</Button>
            <Separator/>
            <Button Command="{Binding SaveCommand}" ToolTip="Сохранить (Ctrl+S)" Template="{StaticResource SaveButtonTemplate}"/>
            <Button Command="{Binding CancelCommand}" ToolTip="Отменить" Template="{StaticResource CancelButtonTemplate}"/>
        </ToolBar>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ЧАСТЬ: список клиентов с DataTemplate -->
            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="📋 Список клиентов" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <!-- ✅ Используем DataTemplate вместо GridView -->
                    <ListBox x:Name="lvClients" 
                             Height="350" 
                             SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                             ItemTemplate="{StaticResource ClientCardTemplate}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                    
                    <TextBlock Text="💡 Ctrl+N - добавить | Ctrl+E - редактировать | Ctrl+D - удалить | Ctrl+S - сохранить" 
                               FontSize="9" Foreground="Gray" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ПРАВАЯ ЧАСТЬ: ФОРМА ДЛЯ ВВОДА/РЕДАКТИРОВАНИЯ -->
            <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="10,0,0,0" Padding="10">
                <StackPanel>
                    <TextBlock Text="✏️ Форма ввода / редактирования" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <!-- Поле ФИО - Двусторонняя привязка -->
                    <TextBlock Text="ФИО:" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                             Height="35" Margin="0,0,0,15" IsEnabled="{Binding IsEditMode}"/>

                    <!-- Поле Телефон - Двусторонняя привязка -->
                    <TextBlock Text="Телефон:" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                             Height="35" Margin="0,0,0,15" IsEnabled="{Binding IsEditMode}"/>

                    <!-- Поле Email - Двусторонняя привязка -->
                    <TextBlock Text="Email:" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                             Height="35" Margin="0,0,0,15" IsEnabled="{Binding IsEditMode}"/>

                    <!-- ✅ Тип клиента - Односторонняя привязка (OneWay) для ComboBox -->
                    <TextBlock Text="Тип клиента:" FontWeight="Bold" Margin="0,0,0,3"/>
                    <ComboBox x:Name="cbClientType" 
                              ItemsSource="{Binding ClientTypes, Mode=OneWay}"
                              SelectedItem="{Binding SelectedClientStatus, Mode=TwoWay}"
                              IsEnabled="{Binding IsEditMode}"
                              Height="35" Margin="0,0,0,20" Padding="5"/>

                    <!-- Статус редактирования -->
                    <Border Background="#FFF0F0F0" CornerRadius="5" Padding="10" Margin="0,5">
                        <TextBlock x:Name="tbStatus" Text="⚡ Режим: просмотр" FontSize="12" TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>