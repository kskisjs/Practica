<Window x:Class="CRMApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CRM - Система управления клиентами" 
        Height="450" 
        Width="700"
        WindowStartupLocation="CenterScreen">

    <!-- Grid - контейнер, который делит окно на колонки и строки -->
    <Grid Margin="10">
        <!-- Делим окно на 2 колонки: левая 2.5 части, правая 1 часть -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== ЛЕВАЯ ЧАСТЬ: Список клиентов ========== -->
        <Border Grid.Column="0" 
                BorderBrush="LightGray" 
                BorderThickness="1" 
                CornerRadius="5"
                Padding="10">
            <StackPanel>
                <!-- Заголовок -->
                <TextBlock Text="Список клиентов" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10"/>

                <!-- ListView - показывает список клиентов в виде таблицы -->
                <ListView x:Name="lvClients" 
                          Height="300" 
                          SelectionChanged="LvClients_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ФИО" 
                                            DisplayMemberBinding="{Binding FullName}" 
                                            Width="180"/>
                            <GridViewColumn Header="Телефон" 
                                            DisplayMemberBinding="{Binding Phone}" 
                                            Width="120"/>
                            <GridViewColumn Header="Email" 
                                            DisplayMemberBinding="{Binding Email}" 
                                            Width="150"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>

        <!-- ========== ПРАВАЯ ЧАСТЬ: Кнопки управления ========== -->
        <Border Grid.Column="1" 
                BorderBrush="LightGray" 
                BorderThickness="1" 
                CornerRadius="5"
                Margin="10,0,0,0"
                Padding="10">
            <StackPanel>
                <TextBlock Text="Управление" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,20"/>

                <!-- Кнопки: ширина 100, отступ снизу 10 -->
                <Button x:Name="btnAdd" 
                        Content="➕ Добавить" 
                        Height="35" 
                        Margin="0,0,0,10"
                        Click="BtnAdd_Click"/>

                <Button x:Name="btnEdit" 
                        Content="✏️ Редактировать" 
                        Height="35" 
                        Margin="0,0,0,10"
                        Click="BtnEdit_Click"/>

                <Button x:Name="btnDelete" 
                        Content="🗑 Удалить" 
                        Height="35" 
                        Margin="0,0,0,10"
                        Click="BtnDelete_Click"/>

                <!-- Разделитель -->
                <Separator Margin="0,20,0,20"/>

                <!-- Информация о выбранном клиенте -->
                <TextBlock Text="Выбранный клиент:" 
                           FontWeight="Bold" 
                           Margin="0,0,0,5"/>
                <TextBlock x:Name="tbSelectedClient" 
                           Text="(не выбран)" 
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>